<Dialog
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    title="{i18n>modalNamePrint}"
    id="PrintDialog"
    stretchOnPhone="true"
    class="customDialog"
>
    <content>
        <VBox id="vBoxMainPrint"
              class="sapUiSmallMargin customVBoxPrint"
              width="100%">                

             <VBox id="vBoxProductCode">
                <Label id="lblProductCode"
                    text="{i18n>columnProductCode}*"
                    class="customLabel"
                />
              <Select id="selProductCode"
                  class="customInput customSelect"
                  selectedKey=""
                  change="onProductChange"
                  items="{ path: 'ProductModel>/' }">

                  <core:Item id="coiProductCode"
                      key="{ProductModel>Matnr}"
                      text="{ProductModel>Description}" />
              </Select>
            </VBox>    
   
            <VBox id="vBoxProduct">
                <Label
                    id="lblProduct"
                    text="{i18n>columnProduct}*"
                    class="customLabel"
                />
                <Input
                    id="inpProduct"
                    placeholder="{i18n>columnProduct}"
                     value="{ProductModel>/Maktx}"
                    class="customInput"
                />
            </VBox>     

            <VBox id="vBoxQuantityPallets">
                <Label
                    id="lblQuantityPallets"
                    text="{i18n>columnQuantityPallets}*"
                    class="customLabel"
                />
                <Input
                    id="inpQuantityPallets"
                    placeholder="{i18n>columnQuantityPallets}"
                    class="customInput"
                />
            </VBox>

            <VBox id="vBoxBoxesNumber">
                <Label
                    id="lblBoxesNumber"
                    text="{i18n>columnNumberBoxes}*"
                    class="customLabel"
                />
                <Input
                    id="inpBoxesNumber"
                    placeholder="{i18n>columnNumberBoxes}"
                    class="customInput"
                />
            </VBox>

            <VBox id="vBoxLocation">
                <Label id="lblLocation"
                    text="{i18n>columnLocation}*"
                    class="customLabel"
                />
                <Input id="inpLocation"
                    placeholder="{i18n>columnLocation}"
                    class="customInput"
                />
            </VBox>

            <VBox id="vBoxProductionLines">
                <Label id="lblProductionLine"
                    text="{i18n>columnProductionLine}*"
                    class="customLabel"
                />
              <Select id="selProductionLines"
                  class="customInput customSelect"
                  selectedKey=""
                  items="{ path: 'ProductionLineModel>/' }">

                  <core:Item id="coiProductionLines"
                      key="{ProductionLineModel>Arbpl}"
                      text="{ProductionLineModel>Description}" />
              </Select>
            </VBox>

            <VBox id="vBoxDocument">
                <Label id="lblDocument"
                    text="{i18n>columnDocument}*"
                    class="customLabel"
                />
                <Input id="inpDocument"
                    placeholder="{i18n>columnDocument}"
                    class="customInput"
                />
            </VBox>

            <VBox id="vBoxEmbilstado">
                <Label id="lblEmbilstado"
                    text="Embilstado*"
                    class="customLabel"
                />
                <Input id="inpEmbilstado"
                    placeholder="Embilstado"
                    class="customInput"
                />
            </VBox>
        </VBox>
    </content>

    <beginButton>
        <Button id="btnAcceptPrint"
            text="{i18n>save}"
            press=".onSave"
            type="Accept"
            class="btnDialogAccept"
        />
    </beginButton>

    <endButton>
        <Button id="btnClosePrint"
            text="{i18n>close}"
            press=".onCancel"
            type="Reject"
            class="btnDialogCancel"
        />
    </endButton>
</Dialog>
