<Dialog
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    title="{i18n>modalNamePrint}"
    id="PrintDialog"
    stretchOnPhone="true"
    class="customDialog customFont"
>
    <content>
        <VBox id="vBoxMainPrint"
              class="sapUiSmallMargin customVBoxPrint"
              width="100%">                

             <VBox id="vBoxProductCode">
                <Label id="lblProductCode"
                    text="{i18n>columnProductCode}*"
                    class="customLabel customFont"
                />
                <ComboBox id="cbxProductCode"
                          class="customInput customSelect customFont"
                          selectedKey="{ProductModel>/Productcode}"
                          change="onProductChange"
                          showSecondaryValues="true"
                          filterSecondaryValues="true"
                          items="{ path: 'ProductModel>/' }">

                          <core:ListItem id="colProductCode" 
                                     key="{ProductModel>Matnr}"
                                     text="{ProductModel>Description}" />
                </ComboBox>
            </VBox>    
   
            <VBox id="vBoxProduct">
                <Label id="lblProduct"
                    text="{i18n>columnProduct}*"
                    class="customLabel customFont"
                />
                <Text id="txtProduct"
                     text="ProductModel>/Product" 
                    class="customInput customText-noDrop customFont"
                />
            </VBox>     

            <VBox id="vBoxQuantityPallets">
                <Label
                    id="lblQuantityPallets"
                    text="{i18n>columnQuantityPallets}*"
                    class="customLabel customFont"
                />
                <Input
                    id="inpQuantityPallets"
                    placeholder="{i18n>columnQuantityPallets}"
                    class="customInput customFont"
                />
            </VBox>

            <VBox id="vBoxBoxesNumber">
                <Label
                    id="lblBoxesNumber"
                    text="{i18n>columnNumberBoxes}*"
                    class="customLabel customFont"
                />
                <Input
                    id="inpBoxesNumber"
                    placeholder="{i18n>columnNumberBoxes}"
                    class="customInput customFont"
                />
            </VBox>

           <VBox id="vBoxlocations">
                <Label id="lbllocations"
                    text="{i18n>columnLocation}*"
                    class="customLabel customFont"
                />
                <ComboBox id="cbxLocations"
                        class="customInput customSelect customFont"
                        selectedKey="{locationsModel>/selectedKey}"
                        showSecondaryValues="true"
                        filterSecondaryValues="true"
                        change="onLocationChange"
                        items="{ path: 'locationsModel>/' }">

                        <core:ListItem  id="colLocations"
                            key="{locationsModel>Werks}"
                            text="{locationsModel>Description}"/>
                </ComboBox>
            </VBox>

            <VBox id="vBoxProductionLines">
                <Label id="lblProductionLine"
                    text="{i18n>columnProductionLine}*"
                    class="customLabel customFont"
                />
                <ComboBox id="cbxProductionLines"
                        class="customInput customSelect customFont"
                        selectedKey="{ProductionLineModel>/selectedKey}"
                        showSecondaryValues="true"
                        filterSecondaryValues="true"
                        items="{ path: 'ProductionLineModel>/' }">

                        <core:ListItem  id="colProductionLines"
                            key="{ProductionLineModel>Arbpl}"
                            text="{ProductionLineModel>Description}"/>
                </ComboBox>
            </VBox>

            <!-- <VBox id="vBoxDocument">
                <Label id="lblDocument"
                    text="{i18n>columnDocument}*"
                    class="customLabel customFont"
                />
                <Input id="inpDocument"
                    placeholder="{i18n>columnDocument}"
                    class="customInput customFont"
                />
            </VBox>

            <VBox id="vBoxEmbilstado">
                <Label id="lblEmbilstado"
                    text="Embilstado*"
                    class="customLabel customFont"
                />
                <Input id="inpEmbilstado"
                    placeholder="Embilstado"
                    class="customInput customFont"
                />
            </VBox> -->
        </VBox>
    </content>

    <beginButton>
        <Button id="btnAcceptPrint"
            text="{i18n>save}"
            press=".onSave"
            type="Accept"
            class="btnDialogAccept"
        />
    </beginButton>

    <endButton>
        <Button id="btnClosePrint"
            text="{i18n>close}"
            press=".onCancel"
            type="Reject"
            class="btnDialogCancel"
        />
    </endButton>
</Dialog>
