<Dialog xmlns="sap.m" xmlns:core="sap.ui.core" 
        title="{i18n>modalNameReader}" 
        id="ReaderDialog" 
        stretchOnPhone="true"
        class="customDialog">
  <content>
  <VBox id="vbxMain" class="sapUiSmallMargin customVBoxReader" width="100%">
      <VBox id="vbxReader" class="itemInput">
         <Label id="lblReader" text="{i18n>columnName}*" class="customLabel"/>
         <Input id="inpReader" placeholder="{i18n>columnName}" class="customInput"/>
      </VBox>
      
      <VBox id="vbxAntenna" class="itemInput">     
          <Label id="lblAntenna" text="{i18n>columnAnntena}*" class="customLabel"/>
          <Input id="inpAntenna" placeholder="{i18n>columnAnntena}" class="customInput"/>
      </VBox>
       
      <VBox id="vbxIP" class="vboxIp itemInput">
           <Label id="lblIp" text="{i18n>columnIp}*" class="customLabel"/>
           <Input id="inpIp" placeholder="{i18n>columnIp}" class="customInput"/>
       </VBox>
    </VBox>
  </content>
  <beginButton>
    <Button id="btnAcceptReader" text="{i18n>save}" press=".onSave"  type="Accept" class="btnDialogAccept"/>
  </beginButton>
  <endButton>
    <Button id="btnCloseReader" text="{i18n>close}" press=".onCancel" type="Reject" class="btnDialogCancel"/>
  </endButton>
</Dialog>
