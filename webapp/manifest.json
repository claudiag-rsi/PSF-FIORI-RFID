{
  "_version": "1.60.0",
  "sap.app": {
    "id": "fw.flexwarehouse",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "crossNavigation": {
      "inbounds": {
        "intent1": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "RFDI",
          "action": "display",
          "title": "Lectura de RFID",
          "icon": "sap.icon://shipping-status"
        }
      }
    },
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.2",
      "toolsId": "164000f1-c62b-49ec-9ab9-7308755e664b"
    },
    "dataSources": {
      "ReaderService": {
        "uri": "/sap/opu/odata/sap/ZREADERS_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      },
      "LabelPrintService": {
        "uri": "/sap/opu/odata/sap/ZLABEL_PRINT_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      },
      "TransactionService": {
        "uri": "/sap/opu/odata/sap/ZTRANSACTIONS_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "fw.flexwarehouse.i18n.i18n"
        }
      },
      "ReaderModel": {
        "dataSource": "ReaderService",
        "type": "sap.ui.model.odata.v2.ODataModel"
      },
      "LabelPrintModel": {
        "dataSource": "LabelPrintService",
        "type": "sap.ui.model.odata.v2.ODataModel"
      },
      "TransactionModel": {
        "dataSource": "TransactionService",
        "type": "sap.ui.model.odata.v2.ODataModel"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/constants.css"
        },
        {
          "uri": "css/customToastDialog.css"
        },
        {
          "uri": "css/dialogs.css"
        },
        {
          "uri": "css/reset.css"
        },
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "fw.flexwarehouse.view",
        "async": true,
        "viewPath": "fw.flexwarehouse.view"
      },
      "routes": [
        {
          "name": "Readers",
          "pattern": "",
          "target": "TargetReaders"
        },
        {
          "name": "Print",
          "pattern": "Print",
          "target": "TargetPrint"
        },
        {
          "name": "Transactions",
          "pattern": "Transactions",
          "target": "TargetTransactions"
        }
      ],
      "targets": {
        "TargetReaders": {
          "viewName": "Readers",
          "viewId": "Readers",
          "viewLevel": 1
        },
        "TargetPrint": {
          "viewName": "Print",
          "viewId": "Print",
          "viewLevel": 1
        },
        "TargetTransactions": {
          "viewName": "Transactions",
          "viewId": "Transactions",
          "viewLevel": 1
        }
      }
    },
    "rootView": {
      "viewName": "fw.flexwarehouse.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}